<UserControl x:Class="DatabasePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CompactGUI"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             d:DataContext="{d:DesignInstance Type=local:DatabaseViewModel}"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid Margin="40 20 40 0" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   VerticalAlignment="Top"
                   d:Text="Database Results" FontSize="26"
                   Foreground="{StaticResource CardForeground}"
                   Text="{local:Localize CompressionDB_DatabaseResults}"
                   Visibility="Visible" />

        <TextBlock Grid.Row="2"
                   Margin="0 0 0 0" HorizontalAlignment="Right" VerticalAlignment="Top"
                   FontSize="12" Foreground="#10FFFFFF">
            <TextBlock.Text>
                <MultiBinding StringFormat="{local:Localize Status_LastFetched}">
                    <Binding Path="LastUpdatedDatabase" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <TextBlock Grid.Row="1"
                   HorizontalAlignment="Left" VerticalAlignment="Center"
                   FontSize="20"
                   Foreground="{StaticResource CardForegroundDisabled}">
            <!--<Run Text="{Binding DatabaseSubmissionsCount, Mode=OneWay}" />
            <Run Text="Submissions" />
            <Run Text="across" />-->
            <Run Text="{Binding DatabaseGamesCount, Mode=OneWay}" />
            <Run d:Text="Games" Text="{local:Localize CompressionDB_DatabaseResults_Games}" />
        </TextBlock>

        <Grid Grid.Row="0" Grid.RowSpan="1"
              Margin="20 0 0 0" HorizontalAlignment="Right">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>


            <!--  Search Box  -->
            <ui:TextBox MinWidth="250"
                        VerticalAlignment="Center"
                        d:PlaceholderText="Search by game name or SteamID..." FontSize="14"
                        PlaceholderText="{local:Localize CompressionDB_DatabaseResults_SearchSteamID}"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <!--  Sorting Menu  -->
            <ui:DropDownButton Grid.Column="1"
                               Height="36"
                               Margin="20 0 0 0" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                               Foreground="{StaticResource LabelForeground}">
                <TextBlock d:Text="Sort By" Text="{local:Localize CompressionDB_DatabaseResults_Sort}" />
                <ui:DropDownButton.Flyout>
                    <ContextMenu>
                        <MenuItem d:Header="Game Name" Header="{local:Localize CompressionDB_DatabaseResults_SortGameName}">
                            <MenuItem d:Header="Ascending"
                                      Command="{Binding SortResultsCommand}"
                                      CommandParameter="GameNameAsc"
                                      Header="{local:Localize CompressionDB_DatabaseResults_SortAscending}" />
                            <MenuItem d:Header="Descending"
                                      Command="{Binding SortResultsCommand}"
                                      CommandParameter="GameNameDesc"
                                      Header="{local:Localize CompressionDB_DatabaseResults_SortDescending}" />
                        </MenuItem>
                        <MenuItem d:Header="SteamID" Header="{local:Localize CompressionDB_DatabaseResults_SortSteamID}">
                            <MenuItem d:Header="Ascending"
                                      Command="{Binding SortResultsCommand}"
                                      CommandParameter="SteamIDAsc"
                                      Header="{local:Localize CompressionDB_DatabaseResults_SortAscending}" />
                            <MenuItem d:Header="Descending"
                                      Command="{Binding SortResultsCommand}"
                                      CommandParameter="SteamIDDesc"
                                      Header="{local:Localize CompressionDB_DatabaseResults_SortDescending}" />
                        </MenuItem>
                        <MenuItem d:Header="Max Savings" Header="{local:Localize CompressionDB_DatabaseResults_SortMaxSavings}">
                            <MenuItem d:Header="Ascending"
                                      Command="{Binding SortResultsCommand}"
                                      CommandParameter="MaxSavingsAsc"
                                      Header="{local:Localize CompressionDB_DatabaseResults_SortAscending}" />
                            <MenuItem d:Header="Descending"
                                      Command="{Binding SortResultsCommand}"
                                      CommandParameter="MaxSavingsDesc"
                                      Header="{local:Localize CompressionDB_DatabaseResults_SortDescending}" />
                        </MenuItem>
                    </ContextMenu>
                </ui:DropDownButton.Flyout>
            </ui:DropDownButton>

        </Grid>


        <Separator Grid.Row="2" Height="1" VerticalAlignment="Bottom" />

        <!--  Results ListView  -->
        <ListView Grid.Row="3"
                  Margin="-20 10" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                  Background="Transparent" BorderBrush="Transparent"
                  Foreground="{StaticResource CardForeground}"
                  ItemsSource="{Binding FilteredResults}"
                  VirtualizingPanel.ScrollUnit="Pixel" VirtualizingPanel.VirtualizationMode="Recycling">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="0 0 0 0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ListViewItem}">
                                <Border Name="Border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="5">
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      d:Content="{TemplateBinding Content}"
                                                      Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>

                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#00000000" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                        </Trigger>
                    </Style.Triggers>

                </Style>

            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0 0 0 12" Padding="12"
                            BorderBrush="#DDD" BorderThickness="0" CornerRadius="6">
                        <StackPanel>
                            <!--  Header: Game Info  -->
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding GameName}" />
                                <Border Margin="14 2" Padding="6 2"
                                        Background="{StaticResource CardBackgroundPressed}"
                                        CornerRadius="4">
                                    <StackPanel Orientation="Horizontal">

                                        <TextBlock VerticalAlignment="Center" Text="{Binding SteamID, StringFormat={}SteamID: {0}}" />
                                    </StackPanel>
                                </Border>

                            </StackPanel>

                            <!--  Compression Results  -->

                            <StackPanel Margin="0 8 0 0" Orientation="Vertical">

                                <ui:Card>

                                    <Grid>
                                        <Grid.RowDefinitions>

                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>

                                        <Grid Margin="0 0 0 10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="130" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock d:Text="MODE" FontWeight="SemiBold"
                                                       Foreground="{StaticResource CardForegroundDisabled}"
                                                       Text="{local:Localize CompressionDB_DatabaseResults_Mode}" />
                                            <TextBlock Grid.Column="1"
                                                       HorizontalAlignment="Right"
                                                       d:Text="BEFORE" FontWeight="SemiBold"
                                                       Foreground="{StaticResource CardForegroundDisabled}"
                                                       Text="{local:Localize Status_Before}" />
                                            <TextBlock Grid.Column="2"
                                                       HorizontalAlignment="Right"
                                                       d:Text="AFTER" FontWeight="SemiBold"
                                                       Foreground="{StaticResource CardForegroundDisabled}"
                                                       Text="{local:Localize Status_After}" />
                                            <TextBlock Grid.Column="3"
                                                       HorizontalAlignment="Right"
                                                       d:Text="SAVINGS" FontWeight="SemiBold"
                                                       Foreground="{StaticResource CardForegroundDisabled}"
                                                       Text="{local:Localize CompressionModeRadio_Savings}" />
                                            <TextBlock Grid.Column="4"
                                                       HorizontalAlignment="Right"
                                                       d:Text="TOTAL RESULTS" FontWeight="SemiBold"
                                                       Foreground="{StaticResource CardForegroundDisabled}"
                                                       Text="{local:Localize CompressionModeRadio_TotalResults}" />

                                        </Grid>

                                        <Grid Grid.Row="1" Visibility="{Binding Result_X4K, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="130" />
                                            </Grid.ColumnDefinitions>

                                            <Label Content="XPRESS4K" />
                                            <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding Result_X4K.BeforeBytes, Converter={StaticResource BytesToReadableConverter}}" />
                                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding Result_X4K.AfterBytes, Converter={StaticResource BytesToReadableConverter}}" />
                                            <TextBlock Grid.Column="3"
                                                       HorizontalAlignment="Right"
                                                       Foreground="#92f1ab"
                                                       Text="{Binding Result_X4K.CompressionSavings, StringFormat={}{0}%}" />
                                            <TextBlock Grid.Column="4" HorizontalAlignment="Right" Text="{Binding Result_X4K.TotalResults}" />
                                        </Grid>

                                        <Grid Grid.Row="2" Visibility="{Binding Result_X8K, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="130" />
                                            </Grid.ColumnDefinitions>

                                            <Label Content="XPRESS8K" />
                                            <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding Result_X8K.BeforeBytes, Converter={StaticResource BytesToReadableConverter}}" />
                                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding Result_X8K.AfterBytes, Converter={StaticResource BytesToReadableConverter}}" />
                                            <TextBlock Grid.Column="3"
                                                       HorizontalAlignment="Right"
                                                       Foreground="#92f1ab"
                                                       Text="{Binding Result_X8K.CompressionSavings, StringFormat={}{0}%}" />
                                            <TextBlock Grid.Column="4" HorizontalAlignment="Right" Text="{Binding Result_X8K.TotalResults}" />
                                        </Grid>
                                        <Grid Grid.Row="3" Visibility="{Binding Result_X16K, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="130" />
                                            </Grid.ColumnDefinitions>

                                            <Label Content="XPRESS16K" />
                                            <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding Result_X16K.BeforeBytes, Converter={StaticResource BytesToReadableConverter}}" />
                                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding Result_X16K.AfterBytes, Converter={StaticResource BytesToReadableConverter}}" />
                                            <TextBlock Grid.Column="3"
                                                       HorizontalAlignment="Right"
                                                       Foreground="#92f1ab"
                                                       Text="{Binding Result_X16K.CompressionSavings, StringFormat={}{0}%}" />
                                            <TextBlock Grid.Column="4" HorizontalAlignment="Right" Text="{Binding Result_X16K.TotalResults}" />
                                        </Grid>
                                        <Grid Grid.Row="4" Visibility="{Binding Result_LZX, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="130" />
                                            </Grid.ColumnDefinitions>

                                            <Label Content="LZX" />
                                            <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding Result_LZX.BeforeBytes, Converter={StaticResource BytesToReadableConverter}}" />
                                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding Result_LZX.AfterBytes, Converter={StaticResource BytesToReadableConverter}}" />
                                            <TextBlock Grid.Column="3"
                                                       HorizontalAlignment="Right"
                                                       Foreground="#92f1ab"
                                                       Text="{Binding Result_LZX.CompressionSavings, StringFormat={}{0}%}" />
                                            <TextBlock Grid.Column="4" HorizontalAlignment="Right" Text="{Binding Result_LZX.TotalResults}" />
                                        </Grid>
                                    </Grid>
                                </ui:Card>


                            </StackPanel>

                            <!--  Poorly Compressed Extensions  -->
                            <StackPanel Margin="0 10 0 0" Orientation="Vertical" Visibility="Collapsed">
                                <TextBlock Margin="0 0 0 4" FontWeight="SemiBold" Text="UNCOMPRESSABLE FILETYPES" />
                                <ItemsControl ItemsSource="{Binding PoorlyCompressedExtensions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="4 2" Padding="6 2"
                                                    Background="{StaticResource CardBackground}"
                                                    CornerRadius="4">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontWeight="Bold" Text="{Binding Extension}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>


    </Grid>
</UserControl>
